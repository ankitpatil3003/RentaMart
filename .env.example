NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Filled by `npx convex dev`
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CONVEX_SITE_URL=

# Clerk JWT issuer domain for Convex auth.config.ts (e.g. https://verb-noun-00.clerk.accounts.dev)
CLERK_JWT_ISSUER_DOMAIN=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
APPLICATION_FEE_CENTS=5000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: attach a Clerk user to Demo Homes LLC when seeding
SEED_LANDLORD_CLERK_ID=

AI_ENABLED=false
NEXT_PUBLIC_AI_ENABLED=false
GROQ_API_KEY=

# Layer 5.1: optional email notifications (Resend)
EMAIL_ENABLED=false
RESEND_API_KEY=
# Optional. Defaults to Resend onboarding sender for test mode.
# EMAIL_FROM=RentaMart <onboarding@resend.dev>

# Layer 2 E2E helpers (optional)
# STRIPE_TEST_CONNECT_ACCOUNT_ID=

# Authenticated trust-path E2E (Playwright + @clerk/testing)
# E2E_TRUST=1
# E2E_CLERK_APPLICANT_EMAIL=landlord+clerk_test@example.com
# E2E_CLERK_ADMIN_EMAIL=admin+clerk_test@example.com
# Also set Convex env E2E_MODE=true on the *dev* deployment only:
#   npx convex env set E2E_MODE true
# Never enable E2E_MODE on production.

# Trusted-org listing fast-path (optional; default 3)
# TRUSTED_ORG_MIN_APPROVED_LISTINGS=3
